@page "/recetas"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@using System.Text.RegularExpressions
@attribute [Authorize]
@inject IRecetaService recetaService
@inject IComentarioService comentarioService
@inject IRatingService ratingService
@inject ITokenService tokenService
@inject AuthenticationStateProvider authStateProvider
@inject IJSRuntime JSRuntime
@inject NavigationManager Navigation

<PageTitle>Recetas</PageTitle>

<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h1 class="h3 text-brand mb-1">Recetas</h1>
                    <p class="text-muted mb-0">Administra tus recetas</p>
                </div>
                <button class="btn btn-brand" @onclick="AbrirModalCrear">
                    <span class="bi bi-plus-circle"></span> Nueva Receta
                </button>
            </div>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(mensajeError))
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <strong>Error:</strong> @mensajeError
            <button type="button" class="btn-close" @onclick="() => mensajeError = string.Empty"></button>
        </div>
    }
    @if (!string.IsNullOrEmpty(mensajeExito))
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <strong>Éxito:</strong> @mensajeExito
            <button type="button" class="btn-close" @onclick="() => mensajeExito = string.Empty"></button>
        </div>
    }

    <div class="row mb-3">
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-12 col-md-6 col-lg-4">
                            <input type="text" class="form-control" placeholder="Buscar receta..."
                                   @bind="busqueda" @bind:event="oninput" />
                        </div>
                        <div class="col-12 col-md-6 col-lg-3">
                            <button class="btn btn-outline-secondary w-100" @onclick="LimpiarBusqueda">
                                <span class="bi bi-x-circle"></span> Limpiar
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        @if (recetas == null)
        {
            <div class="col-12">
                <div class="text-center py-5">
                    <div class="spinner-border text-brand" role="status">
                        <span class="visually-hidden">Cargando...</span>
                    </div>
                    <p class="text-muted mt-3">Cargando recetas...</p>
                </div>
            </div>
        }
        else if (!recetas.Any())
        {
            <div class="col-12">
                <div class="alert alert-info">
                    <h5 class="alert-heading">No hay recetas</h5>
                    <p class="mb-0">Comienza creando tu primera receta.</p>
                </div>
            </div>
        }
        else
        {
            @foreach (var receta in RecetasFiltradas)
            {
                var comentarios = ObtenerComentarios(receta.Id);
                var pasos = ObtenerPasosInstrucciones(receta.Instrucciones).ToList();
                var promedio = ObtenerPromedioRating(receta.Id);
                var totalRatings = ObtenerTotalRatings(receta.Id);
                var miRating = ObtenerMiRating(receta.Id);
                var estrellasActivas = ObtenerEstrellasActivas(receta.Id, miRating);
                var yaVoto = miRating is not null;
                comentariosNuevos.TryAdd(receta.Id, string.Empty);

                <div class="col-12 col-sm-6 col-md-4 col-lg-3 mb-3">
                    <div class="card h-100 border-0 shadow-sm">
                        <div class="card-body d-flex flex-column">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <h5 class="card-title text-brand mb-0">
                                    <a class="text-decoration-none text-brand" style="cursor:pointer" @onclick="() => IrADetalle(receta.Id)">@receta.Titulo</a>
                                </h5>
                            </div>

                            <p class="card-text text-muted small flex-grow-1">
                                @(string.IsNullOrWhiteSpace(receta.Descripcion) ? "Sin descripción" : receta.Descripcion)
                            </p>

                            @if (pasos.Count > 0)
                            {
                                <div class="mb-2">
                                    <small class="text-muted d-block mb-1">Instrucciones (extracto)</small>
                                    <p class="mb-0 small text-muted">@pasos[0]</p>
                                </div>
                            }

                            <div class="d-flex justify-content-between align-items-center mb-2 flex-wrap gap-2">
                                <span class="badge bg-light text-dark border">
                                    <span class="bi bi-chat-left-text"></span> @comentarios.Count comentario@(comentarios.Count == 1 ? "" : "s")
                                </span>
                                <span class="badge bg-light text-dark border">
                                    <span class="bi bi-star-fill text-warning"></span> @promedio.ToString("0.0") (@totalRatings)
                                </span>
                            </div>

                            <div class="mb-3">
                                <small class="text-muted d-block mb-1">Tu valoración</small>
                                <div class="d-flex align-items-center gap-1">
                                    @for (var estrella = 1; estrella <= 5; estrella++)
                                    {
                                        var estrellaActual = estrella;
                                        <button type="button"
                                                class="btn btn-link p-0 border-0 text-decoration-none"
                                                title="Calificar con @estrellaActual estrella@(estrellaActual == 1 ? "" : "s")"
                                                @onmouseover="() => EstablecerHoverRating(receta.Id, estrellaActual)"
                                                @onmouseout="() => LimpiarHoverRating(receta.Id)"
                                                @onclick="() => Votar(receta.Id, estrellaActual)"
                                                disabled="@yaVoto">
                                            <span class="bi @(estrellaActual <= estrellasActivas ? "bi-star-fill text-warning" : "bi-star text-muted") fs-5"></span>
                                        </button>
                                    }
                                </div>
                                <small class="text-muted">@(yaVoto ? $"Ya calificaste con {miRating!.Estrellas:0.#} estrella{(Math.Abs(miRating.Estrellas - 1) < 0.0001 ? string.Empty : "s")}." : "Haz click en una estrella para votar.")</small>
                            </div>

                            <div class="mb-3">
                                <small class="text-muted d-block mb-1">Comentarios</small>
                                @if (comentarios.Count == 0)
                                {
                                    <div class="small text-muted">Aún no hay comentarios.</div>
                                }
                                else
                                {
                                    <ul class="list-unstyled mb-2">
                                        @foreach (var cm in comentarios.Take(2))
                                        {
                                            <li class="small mb-2">
                                                <div class="text-muted">@cm.UsuarioNombre · @cm.CreadoUtc.ToLocalTime().ToString("g")</div>
                                                <div>@cm.Contenido</div>
                                            </li>
                                        }
                                    </ul>
                                    if (comentarios.Count > 2)
                                    {
                                        <button class="btn btn-link p-0 small link-brand" @onclick="() => IrADetalle(receta.Id)">Ver todos</button>
                                    }
                                }

                                <div class="input-group input-group-sm mt-2">
                                    <input class="form-control" placeholder="Escribe un comentario..." @bind="comentariosNuevos[receta.Id]" />
                                    <button class="btn btn-outline-primary" @onclick="() => AgregarComentario(receta.Id)">Comentar</button>
                                </div>
                            </div>

                            <div class="border-top pt-2 mt-auto">
                                <small class="text-muted d-block">
                                    <span class="bi bi-clock"></span> Prep: @receta.TiempoPreparacionMinutos min | Cocción: @receta.TiempoCoccionMinutos min
                                </small>
                                <small class="text-muted d-block">
                                    <span class="bi bi-people"></span> Porciones: @receta.Porciones
                                </small>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
    </div>

    <div class="row mt-4">
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white">
                    <h5 class="mb-0">Vista de Lista</h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th scope="col">ID</th>
                                    <th scope="col">Título</th>
                                    <th scope="col">Descripción</th>
                                    <th scope="col">Tiempos</th>
                                    <th scope="col">Porciones</th>
                                    <th scope="col" class="text-end">Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (recetas != null && recetas.Any())
                                {
                                    @foreach (var receta in RecetasFiltradas.OrderBy(r => r.Id))
                                    {
                                        <tr>
                                            <td>@receta.Id</td>
                                            <td class="fw-semibold">@receta.Titulo</td>
                                            <td class="text-muted">@(string.IsNullOrWhiteSpace(receta.Descripcion) ? "-" : receta.Descripcion)</td>
                                            <td>@receta.TiempoPreparacionMinutos/@receta.TiempoCoccionMinutos min</td>
                                            <td>@receta.Porciones</td>
                                            <td class="text-end">
                                                <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => AbrirModalEditar(receta)">
                                                    <span class="bi bi-pencil"></span>
                                                </button>
                                                <button class="btn btn-sm btn-outline-danger" @onclick="() => EliminarReceta(receta.Id)">
                                                    <span class="bi bi-trash"></span>
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="6" class="text-center text-muted py-4">
                                            No hay recetas para mostrar
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@if (mostrarModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(recetaEditando == null ? "Nueva Receta" : "Editar Receta")</h5>
                    <button type="button" class="btn-close" @onclick="CerrarModal"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label">Título <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" @bind="tituloReceta" placeholder="Ej: Tacos al pastor..." />
                        </div>
                        <div class="col-12">
                            <label class="form-label">Descripción</label>
                            <textarea class="form-control" rows="3" @bind="descripcionReceta" placeholder="Describe brevemente la receta..."></textarea>
                        </div>
                        <div class="col-12">
                            <label class="form-label">Instrucciones <span class="text-danger">*</span></label>
                            <textarea class="form-control" rows="5" @bind="instruccionesReceta" placeholder="Paso a paso..."></textarea>
                        </div>
                        <div class="col-12 col-md-4">
                            <label class="form-label">Tiempo Prep. (min)</label>
                            <input type="number" min="0" class="form-control" @bind="tiempoPreparacionReceta" />
                        </div>
                        <div class="col-12 col-md-4">
                            <label class="form-label">Tiempo Cocción (min)</label>
                            <input type="number" min="0" class="form-control" @bind="tiempoCoccionReceta" />
                        </div>
                        <div class="col-12 col-md-4">
                            <label class="form-label">Porciones</label>
                            <input type="number" min="1" class="form-control" @bind="porcionesReceta" />
                        </div>
                        <div class="col-12">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="publicadaCheck" @bind="publicadaReceta" />
                                <label class="form-check-label" for="publicadaCheck">Publicada</label>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CerrarModal">Cancelar</button>
                    <button type="button" class="btn btn-brand" @onclick="GuardarReceta" disabled="@guardando">
                        @(recetaEditando == null ? "Crear" : "Guardar cambios")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<RecetaDto>? recetas;
    private Dictionary<int, List<ComentarioDto>> comentariosPorReceta = new();
    private Dictionary<int, List<RatingDto>> ratingsPorReceta = new();
    private Dictionary<int, int> hoverRatingsPorReceta = new();
    private Dictionary<int, string> comentariosNuevos = new();
    private string? usuarioIdActual;
    private string busqueda = "";
    private bool mostrarModal = false;
    private bool guardando = false;
    private RecetaDto? recetaEditando = null;
    private string tituloReceta = "";
    private string descripcionReceta = "";
    private string instruccionesReceta = "";
    private int tiempoPreparacionReceta = 0;
    private int tiempoCoccionReceta = 0;
    private int porcionesReceta = 1;
    private bool publicadaReceta = true;
    private string mensajeError = string.Empty;
    private string mensajeExito = string.Empty;

    private IEnumerable<RecetaDto> RecetasFiltradas
    {
        get
        {
            if (recetas == null) return Enumerable.Empty<RecetaDto>();
            if (string.IsNullOrWhiteSpace(busqueda)) return recetas;

            return recetas.Where(r =>
                r.Titulo.Contains(busqueda, StringComparison.OrdinalIgnoreCase) ||
                (r.Descripcion?.Contains(busqueda, StringComparison.OrdinalIgnoreCase) ?? false));
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await CargarUsuarioActual();
        await CargarRecetas();
    }

    private async Task CargarUsuarioActual()
    {
        var storedUserId = await tokenService.ObtenerUsuarioId();
        if (!string.IsNullOrWhiteSpace(storedUserId))
        {
            usuarioIdActual = storedUserId;
            Console.WriteLine($"UsuarioIdActual (localStorage): {usuarioIdActual}");
            return;
        }

        var authState = await authStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        usuarioIdActual = user.FindFirst(ClaimTypes.NameIdentifier)?.Value
            ?? user.FindFirst("userId")?.Value
            ?? user.FindFirst("id")?.Value
            ?? user.FindFirst("sub")?.Value
            ?? user.FindFirst("nameid")?.Value
            ?? user.FindFirst("http://schemas.xmlsoap.org/ws/2005/05/identity/claims/nameidentifier")?.Value
            ?? user.FindFirst("uid")?.Value
            ?? user.Identity?.Name;
            
        Console.WriteLine($"UsuarioIdActual (claims): {usuarioIdActual}");
    }

    private async Task CargarRecetas()
    {
        try
        {
            recetas = await recetaService.ObtenerTodas();
            await CargarComentarios();
            await CargarRatings();
        }
        catch (Exception ex)
        {
            mensajeError = $"Error al cargar recetas: {ex.Message}";
            recetas = new List<RecetaDto>();
            comentariosPorReceta = new Dictionary<int, List<ComentarioDto>>();
            ratingsPorReceta = new Dictionary<int, List<RatingDto>>();
        }
    }

    private async Task CargarComentarios()
    {
        var comentarios = await comentarioService.ObtenerTodos();
        comentariosPorReceta = comentarios
            .GroupBy(c => c.RecetaId)
            .ToDictionary(
                g => g.Key,
                g => g.OrderByDescending(c => c.CreadoUtc).ToList());
    }

    private async Task CargarRatings()
    {
        var ratings = await ratingService.ObtenerTodos();
        ratingsPorReceta = ratings
            .GroupBy(r => r.RecetaId)
            .ToDictionary(
                g => g.Key,
                g => g.OrderByDescending(r => r.Id).ToList());
    }

    private async Task CargarRatingsDeReceta(int recetaId)
    {
        var ratings = await ratingService.ObtenerPorReceta(recetaId);
        ratingsPorReceta[recetaId] = ratings
            .OrderByDescending(r => r.Id)
            .ToList();
    }

    private void AbrirModalCrear()
    {
        recetaEditando = null;
        tituloReceta = "";
        descripcionReceta = "";
        instruccionesReceta = "";
        tiempoPreparacionReceta = 0;
        tiempoCoccionReceta = 0;
        porcionesReceta = 1;
        publicadaReceta = true;
        mensajeError = string.Empty;
        mostrarModal = true;
    }

    private void AbrirModalEditar(RecetaDto receta)
    {
        recetaEditando = receta;
        tituloReceta = receta.Titulo;
        descripcionReceta = receta.Descripcion ?? "";
        instruccionesReceta = receta.Instrucciones;
        tiempoPreparacionReceta = receta.TiempoPreparacionMinutos;
        tiempoCoccionReceta = receta.TiempoCoccionMinutos;
        porcionesReceta = receta.Porciones;
        publicadaReceta = receta.EstaPublicado;
        mensajeError = string.Empty;
        mostrarModal = true;
    }

    private void CerrarModal()
    {
        mostrarModal = false;
        recetaEditando = null;
        mensajeError = string.Empty;
    }

    private async Task GuardarReceta()
    {
        if (string.IsNullOrWhiteSpace(tituloReceta) || string.IsNullOrWhiteSpace(instruccionesReceta))
        {
            mensajeError = "Título e instrucciones son requeridos";
            return;
        }

        guardando = true;
        mensajeError = string.Empty;
        mensajeExito = string.Empty;

        try
        {
            if (recetaEditando == null)
            {
                var nuevaReceta = new RecetaCreacionDto
                {
                    Titulo = tituloReceta,
                    Descripcion = string.IsNullOrWhiteSpace(descripcionReceta) ? null : descripcionReceta,
                    Instrucciones = instruccionesReceta,
                    TiempoPreparacionMinutos = tiempoPreparacionReceta,
                    TiempoCoccionMinutos = tiempoCoccionReceta,
                    Porciones = porcionesReceta,
                    EstaPublicado = publicadaReceta
                };

                var resultado = await recetaService.CrearReceta(nuevaReceta);
                if (resultado == null)
                {
                    mensajeError = "No se pudo crear la receta";
                    return;
                }

                mensajeExito = "Receta creada exitosamente";
                await CargarRecetas();
                CerrarModal();
            }
            else
            {
                var recetaModificacion = new RecetaModificacionDto
                {
                    Titulo = tituloReceta,
                    Descripcion = string.IsNullOrWhiteSpace(descripcionReceta) ? null : descripcionReceta,
                    Instrucciones = instruccionesReceta,
                    TiempoPreparacionMinutos = tiempoPreparacionReceta,
                    TiempoCoccionMinutos = tiempoCoccionReceta,
                    Porciones = porcionesReceta,
                    EstaPublicado = publicadaReceta
                };

                var resultado = await recetaService.ActualizarReceta(recetaEditando.Id, recetaModificacion);
                if (!resultado)
                {
                    mensajeError = "No se pudo actualizar la receta";
                    return;
                }

                mensajeExito = "Receta actualizada exitosamente";
                await CargarRecetas();
                CerrarModal();
            }
        }
        catch (Exception ex)
        {
            mensajeError = $"Error: {ex.Message}";
        }
        finally
        {
            guardando = false;
        }
    }

    private async Task EliminarReceta(int id)
    {
        if (!await JSRuntime.InvokeAsync<bool>("confirm", "¿Estás seguro de eliminar esta receta?"))
            return;

        mensajeError = string.Empty;
        mensajeExito = string.Empty;

        try
        {
            var resultado = await recetaService.EliminarReceta(id);
            if (!resultado)
            {
                mensajeError = "No se pudo eliminar la receta";
                return;
            }

            mensajeExito = "Receta eliminada exitosamente";
            await CargarRecetas();
        }
        catch (Exception ex)
        {
            mensajeError = $"Error al eliminar: {ex.Message}";
        }
    }

    private void LimpiarBusqueda()
    {
        busqueda = "";
    }

    private void IrADetalle(int recetaId)
    {
        Navigation.NavigateTo($"/receta/{recetaId}");
    }

    private async Task Votar(int recetaId, int valor)
    {
        if (string.IsNullOrWhiteSpace(usuarioIdActual))
        {
            usuarioIdActual = await tokenService.ObtenerUsuarioId();
        }
        if (ObtenerMiRating(recetaId) is not null)
        {
            mensajeError = "Ya calificaste esta receta.";
            StateHasChanged();
            return;
        }

        mensajeError = string.Empty;
        mensajeExito = string.Empty;

        var creado = await ratingService.CrearRating(new RatingCreacionDto
        {
            RecetaId = recetaId,
            Estrellas = valor,
            UsuarioId = usuarioIdActual ?? string.Empty
        });

        if (creado is null)
        {
            mensajeError = "No se pudo guardar la valoración. Verifica que hayas iniciado sesión o que no hayas votado antes.";
            StateHasChanged();
            return;
        }

        await CargarRatingsDeReceta(recetaId);
        hoverRatingsPorReceta.Remove(recetaId);
        mensajeExito = "Valoración guardada exitosamente.";
        StateHasChanged();
    }

    private async Task AgregarComentario(int recetaId)
    {
        if (!comentariosNuevos.TryGetValue(recetaId, out var contenido) || string.IsNullOrWhiteSpace(contenido))
        {
            mensajeError = "Escribe un comentario antes de enviar.";
            mensajeExito = string.Empty;
            StateHasChanged();
            return;
        }

        mensajeError = string.Empty;
        mensajeExito = string.Empty;

        var dto = new ComentarioCreacionDto
        {
            Contenido = contenido.Trim(),
            RecetaId = recetaId
        };

        var creado = await comentarioService.CrearComentario(dto);
        if (creado == null)
        {
            mensajeError = "No se pudo crear el comentario. Verifica que estés autenticado.";
            StateHasChanged();
            return;
        }

        if (!comentariosPorReceta.TryGetValue(recetaId, out var lista))
        {
            lista = new List<ComentarioDto>();
            comentariosPorReceta[recetaId] = lista;
        }

        lista.Insert(0, creado);
        comentariosNuevos[recetaId] = string.Empty;
        mensajeExito = "Comentario agregado exitosamente.";
        StateHasChanged();
    }

    private void EstablecerHoverRating(int recetaId, int valor)
    {
        if (ObtenerMiRating(recetaId) is null)
        {
            hoverRatingsPorReceta[recetaId] = valor;
        }
    }

    private void LimpiarHoverRating(int recetaId)
    {
        hoverRatingsPorReceta.Remove(recetaId);
    }

    private List<ComentarioDto> ObtenerComentarios(int recetaId)
    {
        if (comentariosPorReceta.TryGetValue(recetaId, out var comentarios))
        {
            return comentarios;
        }

        return new List<ComentarioDto>();
    }

    private List<RatingDto> ObtenerRatings(int recetaId)
    {
        if (ratingsPorReceta.TryGetValue(recetaId, out var ratings))
        {
            return ratings;
        }

        return new List<RatingDto>();
    }

    private RatingDto? ObtenerMiRating(int recetaId)
    {
        if (string.IsNullOrWhiteSpace(usuarioIdActual))
        {
            return null;
        }

        return ObtenerRatings(recetaId).FirstOrDefault(r => r.UsuarioId == usuarioIdActual);
    }

    private double ObtenerPromedioRating(int recetaId)
    {
        var ratings = ObtenerRatings(recetaId);
        return ratings.Count == 0 ? 0 : ratings.Average(r => r.Estrellas);
    }

    private int ObtenerTotalRatings(int recetaId)
    {
        return ObtenerRatings(recetaId).Count;
    }

    private double ObtenerEstrellasActivas(int recetaId, RatingDto? miRating)
    {
        if (hoverRatingsPorReceta.TryGetValue(recetaId, out var hover))
        {
            return hover;
        }

        return miRating?.Estrellas ?? 0;
    }

    private IEnumerable<string> ObtenerPasosInstrucciones(string instrucciones)
    {
        var texto = (instrucciones ?? string.Empty).Trim();
        if (string.IsNullOrWhiteSpace(texto))
        {
            return new[] { "Sin instrucciones." };
        }

        var pasos = Regex.Split(texto, @"\r?\n\s*\r?\n|\r?\n|(?<=\.)\s+(?=[A-ZÁÉÍÓÚÑ0-9])|(?<=;)\s+")
            .Select(p => p.Trim())
            .Where(p => !string.IsNullOrWhiteSpace(p))
            .Select(p => Regex.Replace(p, @"^[\-\*\u2022]\s*", ""))
            .Select(p => Regex.Replace(p, @"^\d+[\.\)\-:]\s*", ""))
            .ToList();

        return pasos.Count == 0 ? new[] { texto } : pasos;
    }
}
